# Witness Configuration
# Copy to .env and fill in values

# World API — blockchain gateway (confirmed 2026-03-07)
WITNESS_WORLD_API_BASE=https://blockchain-gateway-stillness.live.tech.evefrontier.com

# Polling interval in seconds
WITNESS_POLL_INTERVAL_SECONDS=30

# Database path
WITNESS_DB_PATH=data/witness.db

# Discord bot token (from Discord Developer Portal)
WITNESS_DISCORD_TOKEN=

# Default Discord webhook URL for alerts
WITNESS_DISCORD_WEBHOOK_URL=

# Anthropic API key for narrative generation
WITNESS_ANTHROPIC_API_KEY=

# Warden (autonomous threat intelligence loop)
WITNESS_WARDEN_ENABLED=true
WITNESS_WARDEN_MAX_ITERATIONS=10
WITNESS_WARDEN_MAX_DURATION_HOURS=24
WITNESS_WARDEN_INTERVAL_SECONDS=300
